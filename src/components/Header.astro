---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<a href="https://sam-pastor-storyteller.lovable.app/" target="_blank" rel="noopener noreferrer">About</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: var(--surface);
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 900px;
		margin: 0 auto;
		height: 60px;
	}
	.site-title {
		font-size: 1em;
		font-weight: 700;
		text-decoration: none;
		color: var(--text);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		font-size: 0.85em;
	}
	.site-title:hover {
		color: var(--accent-gold);
	}
	.nav-links {
		display: flex;
		gap: 0.25em;
	}
	.nav-links a {
		padding: 0.5em 0.75em;
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.9em;
		border-radius: 4px;
		transition: color 0.15s, background 0.15s;
	}
	.nav-links a:hover,
	.nav-links a.active {
		color: var(--text);
		background: var(--surface-2);
	}
</style>
